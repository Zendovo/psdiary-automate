# PS Diary Bot Configuration

# API Configuration
# Choose one of the following:

# Option 1: OpenAI API
API_TYPE=openai
OPENAI_API_KEY=your_openai_api_key_here

# Option 2: Google Gemini API (free tier available - Recommended!)
# API_TYPE=gemini
# GEMINI_API_KEY=your_gemini_api_key_here

# Option 3: Custom API endpoint
# API_TYPE=custom
# API_URL=your_custom_api_url
# API_KEY=your_api_key

# Bot Configuration
START_WEEK=1
END_WEEK=24
HEADLESS=false

# Testing Modes
# DRY_RUN: Don't make API calls, don't fill forms, just show what would happen
DRY_RUN=false

# TEST_SAVE: Fill forms with pre-generated answers (no API calls), actually save
# Useful for testing form filling and save functionality without using API credits
# When TEST_SAVE=true, API keys are not required
TEST_SAVE=false
